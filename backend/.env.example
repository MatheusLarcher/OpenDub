# Copie este arquivo para ".env" e ajuste se precisar. Nenhum valor aqui e um segredo --
# sao so parametros de ajuste do pipeline. Nao commite um ".env" com credenciais reais.

# Ambiente Conda separado onde o Seed-VC (conversao de voz opcional) esta instalado.
SEED_VC_CONDA_ENV=seedvc
SEED_VC_STEPS=30

# Controles de geracao do SeamlessM4T v2 para reduzir loops/repeticoes na traducao.
SEAMLESS_TEXT_REPETITION_PENALTY=1.2
SEAMLESS_TEXT_NO_REPEAT_NGRAM_SIZE=3

# Caminho do Seed-VC, se nao estiver em %USERPROFILE%\.codex\cache\seed-vc.
# SEED_VC_DIR=C:\caminho\para\seed-vc
# SEED_VC_PYTHON=C:\caminho\para\envs\seedvc\python.exe
